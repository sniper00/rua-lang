// P4c feature demo: `if let` / `while let`.
// Compile with:
//   cargo run -p ruac --bin ruac -- build tests/fixtures/examples/example_rua_p4c.rua
// then run tests/fixtures/examples/example_rua_p4c.lua with a Lua 5.5 host (rua_rt on path).

fn find(v: Vec<i64>, target: i64) -> Option<i64> {
    let mut i = 0;
    while i < v.len() {
        if v.get(i) == target {
            return Some(i);
        }
        i = i + 1;
    }
    None
}

fn main() {
    let nums = vec![10, 20, 30];

    // `if let` on an Option (pure-nil): binds only when Some.
    if let Some(idx) = find(nums, 20) {
        println!("found 20 at index {}", idx);
    } else {
        println!("20 not found");
    }

    if let Some(idx) = find(nums, 99) {
        println!("found 99 at index {}", idx);
    } else {
        println!("99 not found");
    }

    // `while let`: drain a stack until `pop()` returns None.
    let mut stack = vec![1, 2, 3];
    while let Some(x) = stack.pop() {
        println!("popped {}", x);
    }
    println!("stack drained, len = {}", stack.len());
}
