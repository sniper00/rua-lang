// Example Rua program. Compile with:
//   cargo run -p ruac --bin ruac -- build tests/fixtures/examples/example_rua.rua
// then run the generated tests/fixtures/examples/example_rua.lua with any Lua 5.5 host
// (e.g. the moon_rs binary, or a standalone lua interpreter).

fn abs(x: i64) -> i64 {
    if x < 0 { -x } else { x }
}

fn gcd(a: i64, b: i64) -> i64 {
    let mut x = abs(a);
    let mut y = abs(b);
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

fn is_even(n: i64) -> bool {
    if n == 0 { true } else { is_odd(n - 1) }
}

fn is_odd(n: i64) -> bool {
    if n == 0 { false } else { is_even(n - 1) }
}

fn main() {
    print("gcd(48, 36) = ");
    print(gcd(48, 36));
    print("\n");

    let mut i = 0;
    while i < 6 {
        if i == 3 {
            i = i + 1;
            continue;
        }
        print(i);
        print(" is_even=");
        print(is_even(i));
        print("\n");
        i = i + 1;
    }
}
