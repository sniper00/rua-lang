// moon_rs interop demo (P4c-7): `.ruai` declaration files.
//
// `mod moon;` resolves to `moon.ruai` — a declaration-only module. The compiler
// type-checks calls against its signatures (try changing an argument type or
// arity below), yet emits no Lua for it: `moon::log(..)` lowers to a plain
// `moon.log(..)` against the host-provided global.
//
// Compile:  cargo run -p ruac --bin ruac -- build tests/fixtures/examples/rua_moon/main.rua
// Run:      lua tests/fixtures/examples/rua_moon/run.lua      (from the workspace root;
//           run.lua stubs a `moon` global so this runs under plain Lua 5.5)

mod moon;

use moon::log;

fn main() {
    // `use moon::log;` — desugars to the qualified call, checked as arity 1 / String.
    log("starting up");

    // Fully-qualified call, also checked against moon.ruai.
    moon::log("hello from Rua");

    // Return type flows through: `moon::time` is declared `-> i64`.
    let now = moon::time();
    println!("host time = {}", now);
}
