// Multi-file module demo (P4c-4). Compile with:
//   cargo run -p ruac --bin ruac -- build tests/fixtures/examples/rua_multi/main.rua
// then run tests/fixtures/examples/rua_multi/main.lua with a Lua 5.5 host.
//
// Layout:
//   main.rua        (this file; crate root)
//   math.rua        -> mod math
//   math/trig.rua   -> mod math::trig
//   util.rua        -> mod util

mod math;
mod util;

use math::add;

fn main() {
    println!("math::add       = {}", math::add(2, 3));
    println!("math::trig      = {}", math::trig::triple(4));
    println!("util::greet     = {}", util::greet());
    println!("add (use alias) = {}", add(10, 20));
    println!("add_then_triple = {}", math::add_then_triple(2, 3));
}
