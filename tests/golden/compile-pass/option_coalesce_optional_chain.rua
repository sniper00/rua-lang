struct Profile {
    city: String,
}

impl Profile {
    fn label(&self, suffix: String) -> String {
        self.city + suffix
    }
}

let profile: Option<Profile> = Option::Some(Profile { city: "Shanghai" });
let missing: Option<Profile> = Option::None;
let disabled: Option<bool> = Option::Some(false);

print("{}", disabled ?? true);
print("{}", profile?.city ?? "unknown");
print("{}", missing?.label("!") ?? "unknown");
