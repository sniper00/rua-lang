// Option matching with `if let` and `while let`.

fn find(v: Vec<i64>, target: i64) -> Option<i64> {
    let mut i = 0;
    while i < v.len() {
        if v.get(i) == target {
            return Some(i);
        }
        i = i + 1;
    }
    None
}

fn main() {
    let nums = [10, 20, 30];

    // `if let` on an Option (pure-nil): binds only when Some.
    if let Some(idx) = find(nums, 20) {
        print("found 20 at index {}", idx);
    } else {
        print("20 not found");
    }

    if let Some(idx) = find(nums, 99) {
        print("found 99 at index {}", idx);
    } else {
        print("99 not found");
    }

    // `while let`: drain a stack until `pop()` returns None.
    let mut stack = [1, 2, 3];
    while let Some(x) = stack.pop() {
        print("popped {}", x);
    }
    print("stack drained, len = {}", stack.len());
}
