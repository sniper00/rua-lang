// Lua extern declarations and HashMap construction/method calls.
// Declare ambient Lua globals we call. No Lua code is emitted for this block;
// it just tells the checker these names exist (and documents their shapes).

extern "lua" {
    fn tostring(v: i64) -> String;
}

fn main() {
    // HashMap::new() -> map.new(); methods lower to `m:method(...)`.
    let mut scores = HashMap::new();
    scores.insert("alice", 10);
    scores.insert("bob", 20);
    scores.insert("alice", 15); // overwrite

    print("count = {}", scores.len());
    print("alice = {}", scores.get("alice"));
    print("has bob = {}", scores.contains_key("bob"));

    scores.remove("bob");
    print("after remove, has bob = {}", scores.contains_key("bob"));
    print("count = {}", scores.len());

    // extern function used directly (ambient Lua global).
    print("tostring(42) = {}", tostring(42));
}
