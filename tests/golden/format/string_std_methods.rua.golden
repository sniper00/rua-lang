// String standard-library methods and string concatenation.
//
// Recognized methods lower through the configured `string` runtime export;
// `String + String` lowers to Lua concatenation.

fn shout(name: String) -> String {
    // `+` on strings is concatenation; `to_uppercase` returns a new String.
    "HELLO, ".to_string() + name.to_uppercase()
}

fn main() {
    let s = "Hello, World";
    print("len       = {}", s.len());
    print("upper     = {}", s.to_uppercase());
    print("lower     = {}", s.to_lowercase());
    print("contains  = {}", s.contains("World"));
    print("starts    = {}", s.starts_with("Hello"));
    print("ends      = {}", s.ends_with("World"));
    print("replace   = {}", s.replace("o", "0"));
    print("trimmed   = [{}]", "  padded  ".trim());
    print("repeat    = {}", "ab".repeat(3));
    print("shout     = {}", shout("rua"));

    // `split` / `chars` return `Vec<String>` (0-based, with `.len()`/`.get()`).
    let parts = s.split(", ");
    print("parts     = {} / {}", parts.get(0), parts.get(1));

    let letters = "abc".chars();
    print("chars len = {}", letters.len());
    print("chars[2]  = {}", letters.get(2));
}
