// For loops, numeric ranges, Vec literals, operations, and indexing.

fn sum_to(n: i64) -> i64 {
    let mut total = 0;
    for i in 1..=n {
        total = total + i;
    }
    total
}

fn main() {
    // Numeric range loop.
    print("sum 1..=5 = {}", sum_to(5));

    // Vec literal + push + len + indexing (1-based, like Lua).
    let mut v = [10, 20, 30];
    v.push(40);
    print("len = {}", v.len());
    print("v[1] = {}", v[1]);
    print("v[4] = {}", v[4]);

    // Iterate a Vec by value.
    let mut acc = 0;
    for x in v {
        acc = acc + x;
    }
    print("vec sum = {}", acc);

    // `format` builds a string; `print` writes one complete line.
    let msg = format("({}, {})", 1, 2);
    print("point = ");
    print("{}", msg);
}
