{
  "name": "rua-lang",
  "displayName": "Rua Language",
  "description": "Language support for Rua (Rust-like syntax, transpiles to Lua 5.5) — powered by the rua-lsp language server.",
  "version": "0.1.1",
  "publisher": "BruceZeros",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sniper00/rua"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "rua",
    "lua"
  ],
  "activationEvents": [
    "onLanguage:rua",
    "onCommand:rua.buildFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configurationDefaults": {
      "[rua]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "off"
        },
        "editor.suggestOnTriggerCharacters": true
      }
    },
    "languages": [
      {
        "id": "rua",
        "aliases": [
          "Rua",
          "rua"
        ],
        "extensions": [
          ".rua",
          ".ruai"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rua",
        "scopeName": "source.rua",
        "path": "./syntaxes/rua.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Rua",
      "properties": {
        "rua.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `rua-lsp` executable. Leave empty to use the binary bundled for the current platform, or set an absolute path / `${workspaceFolder}`-relative path to override it."
        },
        "rua.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to the language server."
        },
        "rua.compiler.path": {
          "type": "string",
          "scope": "resource",
          "default": "",
          "markdownDescription": "Path to the `ruac` executable used by **Rua: Build File**. Leave empty to use the binary bundled for the current platform, or set an absolute path / `${workspaceFolder}`-relative path to override it."
        },
        "rua.compiler.args": {
          "type": "array",
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments appended to `ruac build <file>`."
        },
        "rua.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the JSON-RPC communication between VS Code and the Rua language server."
        }
      }
    },
    "commands": [
      {
        "command": "rua.buildFile",
        "title": "Rua: Build File"
      },
      {
        "command": "rua.restartServer",
        "title": "Rua: Restart Language Server"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rua.buildFile",
          "when": "resourceExtname == .rua",
          "group": "navigation@10"
        }
      ],
      "editor/context": [
        {
          "command": "rua.buildFile",
          "when": "editorLangId == rua && resourceExtname == .rua",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "test-extension": "npm run check-types && tsc && npm run compile && cargo build --manifest-path ../../Cargo.toml -p ruac -p rua-lsp --features rua-lsp/lsp && node dist/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
